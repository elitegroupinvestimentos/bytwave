# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Supabase
# Pegue em: https://app.supabase.com → Project Settings → API
# Use a Service Role Key APENAS no backend (nunca exponha no frontend).
# ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─────────────────────────────────────────────
# Binance — Modo seguro por padrão (TESTNET).
# Troque BINANCE_MODE=production somente após validar tudo.
# Crie chaves de TESTNET em: https://testnet.binancefuture.com
# Crie chaves de PRODUÇÃO em: https://www.binance.com/en/my/settings/api-management
# ─────────────────────────────────────────────
BINANCE_MODE=testnet

# ─────────────────────────────────────────────
# Criptografia das API keys salvas no banco.
# Gere com:  openssl rand -hex 32
# (32 bytes em hex = 64 caracteres). NÃO mude depois de salvar chaves.
# ─────────────────────────────────────────────
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# ─────────────────────────────────────────────
# Worker / motor de estratégia
# ─────────────────────────────────────────────
WORKER_INTERVAL_MS=5000
LOG_LEVEL=info

# Limite global de exposição (em USDT) por usuário. 0 desliga o limite.
MAX_EXPOSURE_USDT=0

# ─────────────────────────────────────────────
# Tokens (sistema de uso)
# ─────────────────────────────────────────────
# Tokens grátis ao criar conta nova (0 desliga o grant inicial).
INITIAL_TOKEN_GRANT=100
# Tokens cobrados por ciclo aberto pelo bot (0 desliga a cobrança).
TOKENS_PER_CYCLE=1
# Mostra alerta "tokens acabando" abaixo desse valor.
LOW_TOKENS_THRESHOLD=10

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
# Senha do painel /admin — TROQUE em produção. Comparada contra header
# `x-admin-password` em todas as rotas /api/admin/*.
ADMIN_PASSWORD=troque-isto-em-producao

# ─────────────────────────────────────────────
# Auth (JWT + bcrypt)
# ─────────────────────────────────────────────
# Segredo pra assinar JWTs. Gere com: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
BCRYPT_ROUNDS=10
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS (frontends permitidos em produção)
# ─────────────────────────────────────────────
# "*" libera tudo (só dev). Em prod, lista CSV das origens autorizadas:
#   CORS_ORIGINS=https://bytwave.vercel.app,https://app.bytwave.com.br
CORS_ORIGINS=*
